# =============================================================================
# REQUIRED — Django runtime (AWS VM / docker-compose.prod.yml)
# =============================================================================
# Supabase Postgres (Session mode, port 5432 — not transaction pooler 6543)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require
# Prefer session-mode URL (port 5432). Used when set; otherwise POSTGRES_* above.
DIRECT_URL=

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Host port for Nginx (default 8080). Avoids conflict with other apps on :80/:443.
# HTTP_PORT=8080

# Nginx proxies with Host: backend. Include your public host only if you bypass Nginx.
ALLOWED_HOSTS=backend,localhost,127.0.0.1

# Frontend origin(s) — replace with your deployed frontend URL(s)
CSRF_TRUSTED_ORIGINS=https://your-app.example.com
CORS_ALLOWED_ORIGINS=https://your-app.example.com
FRONTEND_URL=https://your-app.example.com

SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
DATA_TTL_HOURS=24
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# =============================================================================
# RESUME GENERATION — Celery, NVIDIA NIM, FormaTeX PDF compilation
# =============================================================================
# Redis broker URL (redis:// or rediss:// depending on your provider TLS setting)
CELERY_BROKER_URL=
CELERY_TASK_TIME_LIMIT=420

# NVIDIA NIM cloud API (in-process, no agent microservice)
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_API_BASE_URL=
NVIDIA_REQUEST_TIMEOUT=180

# FormaTeX cloud PDF compilation (required for resume PDF generation)
FORMATEX_API_KEY=
FORMATEX_API_BASE_URL=
FORMATEX_ENGINE=auto
FORMATEX_TIMEOUT=120
FORMATEX_USE_SMART_COMPILE=True

# =============================================================================
# CLERK AUTHENTICATION
# =============================================================================
# API Keys: Clerk Dashboard → API keys
# Webhook signing secret: Configure → Webhooks → Signing secret
# Production webhook path (proxied via frontend): /api/v1/auth/clerk/webhook
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=
CLERK_WEBHOOK_SECRET=
CLERK_API_BASE_URL=
# Optional JWT audience; leave blank to skip audience verification
CLERK_AUDIENCE=
CLERK_JWKS_CACHE_TTL=3600
