# =============================================================================
# REQUIRED — Django runtime
# =============================================================================
# Supabase Postgres (Session mode, port 5432 — not transaction pooler 6543)
POSTGRES_HOST=db.xxxxx.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_supabase_password
POSTGRES_SSLMODE=require
SECRET_KEY=""
DEBUG=False
# .onrender.com matches any Render subdomain; add your exact host after first deploy
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,resume-refiner-api-vulk.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
DATA_TTL_HOURS=24
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# =============================================================================
# RESUME GENERATION — Celery, NVIDIA NIM, FormaTeX PDF compilation
# =============================================================================
# Redis Cloud (TLS)
CELERY_BROKER_URL=rediss://default:password@redis-xxxxx.cloud.redislabs.com:6379
CELERY_TASK_TIME_LIMIT=420
# NVIDIA NIM cloud API (in-process, no agent microservice)
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_REQUEST_TIMEOUT=180
# FormaTeX cloud PDF compilation (required for resume PDF generation)
FORMATEX_API_KEY=
FORMATEX_API_BASE_URL=https://api.formatex.io/api/v1
FORMATEX_ENGINE=auto
FORMATEX_TIMEOUT=120
FORMATEX_USE_SMART_COMPILE=True

# =============================================================================
# CLERK AUTHENTICATION
# =============================================================================
# API Keys: https://dashboard.clerk.com/~/api-keys
# Webhook signing secret: Configure → Webhooks → your endpoint → Signing secret
# Webhook URL: https://resume-refiner-api-vulk.onrender.com/api/v1/auth/clerk/webhook
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=
# Optional JWT audience; leave blank to skip audience verification
CLERK_AUDIENCE=
CLERK_JWKS_CACHE_TTL=3600

# =============================================================================
# OPTIONAL — Email (legacy; auth emails are handled by Clerk)
# =============================================================================
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@resume-ai.com
EMAIL_FROM_NAME=Resume AI
FRONTEND_URL=https://your-app.vercel.app
