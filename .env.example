# =============================================================================
# REQUIRED — Django runtime
# =============================================================================
POSTGRES_DB=resume-refiner-db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432
SECRET_KEY=""
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATA_TTL_HOURS=24
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# =============================================================================
# RESUME GENERATION — Celery, AI agent, LaTeX microservice
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=420
AI_AGENT_URL=http://agent:8001
AI_AGENT_TIMEOUT=300
LATEX_SERVICE_URL=http://latex:8002
LATEX_SERVICE_TIMEOUT=30
# Used by the LaTeX microservice (services/latex), not Django settings
LATEX_COMPILE_TIMEOUT=60
# FormaTeX cloud PDF compilation (backend + celery_worker only; never commit the key)
# When set, compile uses FormaTeX /compile/smart; LaTeX microservice still serves templates.
# Free tier: ~15 compilations/month — use local pdflatex (unset key) for dev when possible.
FORMATEX_API_KEY=
FORMATEX_API_BASE_URL=https://api.formatex.io/api/v1
FORMATEX_ENGINE=auto
FORMATEX_TIMEOUT=120
FORMATEX_USE_SMART_COMPILE=True
FORMATEX_FALLBACK_TO_LOCAL=True
# Used by the AI agent microservice (services/agent) — NVIDIA NIM cloud API
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_REQUEST_TIMEOUT=180

# =============================================================================
# CLERK AUTHENTICATION
# =============================================================================
# API Keys: https://dashboard.clerk.com/~/api-keys
# Webhook signing secret: Configure → Webhooks → your endpoint → Signing secret
# Webhook URL: http://localhost:8000/api/v1/auth/clerk/webhook (use a tunnel for local dev)
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=
# Optional JWT audience; leave blank to skip audience verification
CLERK_AUDIENCE=
CLERK_JWKS_CACHE_TTL=3600

# =============================================================================
# OPTIONAL — Email (legacy; auth emails are handled by Clerk)
# =============================================================================
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@resume-ai.com
EMAIL_FROM_NAME=Resume AI
FRONTEND_URL=http://localhost:3000
