# Render environment variables (copy values from your local .env)
#
# Dashboard: https://dashboard.render.com → resume-refiner-env (or your service → Environment)
#
# Minimum required for deploy to succeed:

# Option A — single Supabase session URL (recommended)
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Option B — individual Postgres fields (use if not setting DIRECT_URL)
# POSTGRES_HOST=aws-1-ap-south-1.pooler.supabase.com
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres.PROJECT_REF
# POSTGRES_PASSWORD=your_password
# POSTGRES_SSLMODE=require

SECRET_KEY=your-django-secret-key
CELERY_BROKER_URL=rediss://default:password@your-redis-host:port
NVIDIA_API_KEY=nvapi-...
FORMATEX_API_KEY=fex_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_...
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
