{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserProfile",
  "description": "A structured professional profile, similar to a LinkedIn profile.",
  "type": "object",
  "properties": {
    "personalInfo": {
      "type": "object",
      "required": ["full_name", "email", "phone_number", "location"],
      "properties": {
        "full_name": {
          "type": "string",
          "description": "User's full name.",
          "minLength": 1,
          "maxLength": 255
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's primary email address.",
          "maxLength": 255
        },
        "phone_number": {
          "type": "string",
          "description": "User's contact phone number in format +<countryCode>-<number> (e.g. +91-9876543210).",
          "pattern": "^\\+\\d{1,4}-\\d{6,14}$",
          "maxLength": 50
        },
        "location": {
          "type": "string",
          "description": "City and country, e.g., 'San Francisco, USA'.",
          "maxLength": 255
        },
        "portfolio_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to a personal website or portfolio.",
          "maxLength": 512
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "string",
      "description": "A professional summary or 'About Me' section.",
      "minLength": 10,
      "maxLength": 2500
    },
    "experience": {
      "type": "array",
      "description": "Work experience history.",
      "minItems": 0,
      "maxItems": 25,
      "items": {
        "type": "object",
        "required": ["company", "title", "start_date", "description"],
        "properties": {
          "company": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5000
          }
        },
        "additionalProperties": false
      }
    },
    "education": {
      "type": "array",
      "description": "Educational background.",
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "institution",
          "degree_level",
          "course",
          "specialization",
          "location",
          "grade_type",
          "grade_value",
          "start_date"
        ],
        "properties": {
          "institution": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "degree": {
            "type": "string",
            "maxLength": 255
          },
          "degree_level": {
            "type": "string",
            "enum": [
              "Bachelor's",
              "Master's",
              "Doctorate",
              "Diploma",
              "Associate",
              "High School",
              "Other"
            ]
          },
          "degree_level_other": {
            "type": "string",
            "maxLength": 255
          },
          "course": {
            "type": "string",
            "enum": [
              "BTech",
              "BE",
              "MTech",
              "ME",
              "BSc",
              "MSc",
              "MBA",
              "BCA",
              "MCA",
              "BCom",
              "MCom",
              "BA",
              "MA",
              "PhD",
              "Other"
            ]
          },
          "course_other": {
            "type": "string",
            "maxLength": 255
          },
          "specialization": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "location": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "grade_type": {
            "type": "string",
            "enum": ["percentage", "cgpa"]
          },
          "grade_value": {
            "type": "number"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          }
        },
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "description": "A list of professional skills.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "certifications": {
      "type": "array",
      "description": "Professional certifications.",
      "minItems": 0,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["name", "issuing_organization"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "issuing_organization": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "issue_date": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      }
    },
    "projects": {
      "type": "array",
      "description": "Projects worked on.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "title", "role", "ongoing", "description"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 150
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5000
          },
          "start_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "end_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "ongoing": {
            "type": "boolean"
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 100
            }
          },
          "link": {
            "type": ["string", "null"],
            "format": "uri",
            "description": "Legacy project URL; prefer github_url or deployment_url."
          },
          "github_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "deployment_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "achievements": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 500
            }
          }
        },
        "additionalProperties": false
      }
    },
    "achievements": {
      "type": "array",
      "description": "Professional achievements and accomplishments.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "title", "description"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 250
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "issuer": {
            "type": "string",
            "maxLength": 255
          },
          "location": {
            "type": "string",
            "maxLength": 255
          },
          "is_virtual": {
            "type": "boolean"
          },
          "date": {
            "type": ["string", "null"],
            "format": "date"
          }
        },
        "additionalProperties": false
      }
    },
    "areas_of_interest": {
      "type": "array",
      "description": "Areas of professional interest.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "hobbies": {
      "type": "array",
      "description": "Personal hobbies and interests.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "address": {
      "type": "object",
      "description": "Physical address information.",
      "properties": {
        "street": {
          "type": "string",
          "maxLength": 250
        },
        "city": {
          "type": "string",
          "maxLength": 100
        },
        "region": {
          "type": "string",
          "maxLength": 100
        },
        "country": {
          "type": "string",
          "maxLength": 100
        },
        "postal_code": {
          "type": "string",
          "maxLength": 50
        },
        "geolocation": {
          "type": "object",
          "properties": {
            "lat": {
              "type": "number"
            },
            "lon": {
              "type": "number"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "social_urls": {
      "type": "object",
      "description": "Social media and professional platform URLs.",
      "properties": {
        "linkedin": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "github": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "twitter": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "portfolio": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "website": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "other": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "url"],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "url": {
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "profile_picture": {
      "type": ["object", "null"],
      "description": "Profile picture information.",
      "properties": {
        "url": {
          "type": "string"
        },
        "thumbnail_url": {
          "type": "string"
        },
        "uploaded_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "volunteering": {
      "type": "array",
      "description": "Volunteering experience.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "organization", "role", "description"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "organization": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "location": {
            "type": "string",
            "maxLength": 255
          },
          "start_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "end_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5000
          }
        },
        "additionalProperties": false
      }
    },
    "positions": {
      "type": "array",
      "description": "Board and leadership positions.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "title", "organization", "description"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "organization": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "location": {
            "type": "string",
            "maxLength": 255
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5000
          }
        },
        "additionalProperties": false
      }
    },
    "career_breaks": {
      "type": "array",
      "description": "Career breaks and gaps.",
      "minItems": 0,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["id", "start_date", "reason", "description"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "reason": {
            "type": "string",
            "enum": ["parental", "health", "travel", "education", "other"]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        },
        "additionalProperties": false
      }
    },
    "licenses": {
      "type": "array",
      "description": "Professional licenses.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "name", "issuer"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "issuer": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "license_number": {
            "type": "string",
            "maxLength": 100
          },
          "awarded_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "expiration_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "date": {
            "type": ["string", "null"],
            "format": "date",
            "description": "Legacy award date; prefer awarded_date."
          },
          "url": {
            "type": ["string", "null"],
            "format": "uri"
          }
        },
        "additionalProperties": false
      }
    },
    "trainings": {
      "type": "array",
      "description": "Training courses and certifications.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "title", "provider", "description"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "provider": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "start_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "end_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "venue": {
            "type": "string",
            "maxLength": 255
          },
          "is_virtual": {
            "type": "boolean"
          },
          "date": {
            "type": ["string", "null"],
            "format": "date",
            "description": "Legacy completion date; prefer start_date/end_date."
          },
          "certificate_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        },
        "additionalProperties": false
      }
    },
    "publications": {
      "type": "array",
      "description": "Publications and research papers.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "title", "authors"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "subtitle": {
            "type": "string",
            "maxLength": 500
          },
          "authors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 255
                },
                "affiliation": {
                  "type": "string",
                  "maxLength": 255
                },
                "order": {
                  "type": "integer",
                  "minimum": 1
                },
                "is_corresponding": {
                  "type": "boolean"
                },
                "orcid": {
                  "type": "string",
                  "maxLength": 50
                }
              },
              "additionalProperties": false
            }
          },
          "doi": {
            "type": "string",
            "maxLength": 255
          },
          "pmid": {
            "type": "string",
            "maxLength": 50
          },
          "pmcid": {
            "type": "string",
            "maxLength": 50
          },
          "isbn": {
            "type": "string",
            "maxLength": 50
          },
          "issn": {
            "type": "string",
            "maxLength": 50
          },
          "arxiv_id": {
            "type": "string",
            "maxLength": 50
          },
          "editor": {
            "type": "string",
            "maxLength": 255
          },
          "venue": {
            "type": "string",
            "maxLength": 255
          },
          "volume": {
            "type": "string",
            "maxLength": 50
          },
          "issue": {
            "type": "string",
            "maxLength": 50
          },
          "page_range": {
            "type": "string",
            "maxLength": 100
          },
          "article_number": {
            "type": "string",
            "maxLength": 50
          },
          "date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "online_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "accepted_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "publication_year": {
            "type": "integer",
            "minimum": 1000,
            "maximum": 9999
          },
          "publication_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 100
            }
          },
          "subject_categories": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 100
            }
          },
          "url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "landing_page_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "pdf_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "repository_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "version_label": {
            "type": "string",
            "maxLength": 50
          },
          "version_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "funding_sources": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 255
            }
          },
          "grant_numbers": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 100
            }
          },
          "trial_registry": {
            "type": "string",
            "maxLength": 255
          },
          "ethics_approvals": {
            "type": "string",
            "maxLength": 255
          },
          "copyright_holder": {
            "type": "string",
            "maxLength": 255
          },
          "license": {
            "type": "string",
            "maxLength": 255
          },
          "reuse_permissions": {
            "type": "string",
            "maxLength": 500
          },
          "citation_count": {
            "type": "integer",
            "minimum": 0
          },
          "altmetric_score": {
            "type": "number",
            "minimum": 0
          },
          "language": {
            "type": "string",
            "maxLength": 100
          },
          "publication_type": {
            "type": "string",
            "maxLength": 100
          },
          "document_type": {
            "type": "string",
            "maxLength": 100
          },
          "abstract": {
            "type": "string",
            "maxLength": 5000
          }
        },
        "additionalProperties": false
      }
    },
    "patents": {
      "type": "array",
      "description": "Patents filed or granted.",
      "minItems": 0,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "title", "patent_number", "status"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "patent_number": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "status": {
            "type": "string",
            "enum": ["filed", "granted", "pending"]
          },
          "abstract": {
            "type": "string",
            "maxLength": 5000
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 100
            }
          },
          "application_number": {
            "type": "string",
            "maxLength": 100
          },
          "publication_number": {
            "type": "string",
            "maxLength": 100
          },
          "inventors": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 255
            }
          },
          "applicants": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 255
            }
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 255
            }
          },
          "filing_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "priority_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "publication_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "grant_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "patent_office": {
            "type": "string",
            "maxLength": 255
          },
          "family_id": {
            "type": "string",
            "maxLength": 100
          },
          "ipc_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 50
            }
          },
          "cpc_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 50
            }
          },
          "us_classifications": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 50
            }
          },
          "kind_code": {
            "type": "string",
            "maxLength": 20
          },
          "legal_status": {
            "type": "string",
            "maxLength": 100
          },
          "pct_number": {
            "type": "string",
            "maxLength": 100
          },
          "representative": {
            "type": "string",
            "maxLength": 255
          },
          "url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "drawings_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
